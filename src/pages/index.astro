---
import Layout from "../layouts/Layout.astro";

import './index.css'
---

<Layout>
  <main class="container">
    <section class="hero">
      <div class="hero-content">
        <h1>Todo lo que tu mejor amigo necesita</h1>
        <p>
          Descubrí alimentos premium, accesorios divertidos y el mejor cuidado
          para tus peludos con envíos rápidos a domicilio.
        </p>
        <a href="productos.html" class="btn">Ver Catálogo</a>
      </div>
    </section>

    <section>
      <h2 class="section-title">Comprar por Mascota</h2>
      <div class="categories-grid">
        <a href="productos.html" class="category-card">
          <span class="category-icon">🐶</span>
          <h3>Perros</h3>
        </a>
        <a href="productos.html" class="category-card">
          <span class="category-icon">🐱</span>
          <h3>Gatos</h3>
        </a>
        <a href="productos.html" class="category-card">
          <span class="category-icon">🦜</span>
          <h3>Aves</h3>
        </a>
        <a href="productos.html" class="category-card">
          <span class="category-icon">🐹</span>
          <h3>Roedores</h3>
        </a>
      </div>
    </section>

    <section>
      <h2 class="section-title">Productos Destacados</h2>
      <div class="products-grid">
        <div class="product-card">
          <div class="product-img-placeholder">
            🍖<span class="badge">10% OFF</span>
          </div>
          <div class="product-info">
            <div class="product-brand">Royal Canin</div>
            <div class="product-title">
              Alimento Mini Adulto para Perros - 7,5 Kg
            </div>
            <div class="product-price">$84.600</div>
            <a href="#" class="btn">Agregar al carrito</a>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img-placeholder">🥫</div>
          <div class="product-info">
            <div class="product-brand">Pro Plan</div>
            <div class="product-title">
              Alimento Gato Adulto Pollo y Arroz - 3 Kg
            </div>
            <div class="product-price">$38.900</div>
            <a href="#" class="btn">Agregar al carrito</a>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img-placeholder">
            💎<span class="badge">30% 2da Unid</span>
          </div>
          <div class="product-info">
            <div class="product-brand">Puppis</div>
            <div class="product-title">
              Piedras Sanitarias Silica Gel Lavanda - 3.8 L
            </div>
            <div class="product-price">$17.000</div>
            <a href="#" class="btn">Agregar al carrito</a>
          </div>
        </div>
        <div class="product-card">
          <div class="product-img-placeholder">🛏️</div>
          <div class="product-info">
            <div class="product-brand">Animal Pet</div>
            <div class="product-title">
              Manta Polar Soft para Perro y Gato Gris
            </div>
            <div class="product-price">$8.400</div>
            <a href="#" class="btn">Agregar al carrito</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>
