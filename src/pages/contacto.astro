---
import Layout from "../layouts/Layout.astro"

import './contacto.css'

const idioma = "es"

const campos = {
    es: {
        nombre: "Nombre Completo",
        correo: "Correo Electrónico",
        mensaje: "Mensaje"
    },
    en: {
        nombre: "Name",
        correo: "E-mail",
        mensaje: "Message"
    }
    
}

const tituloSeccion = "Ponete en Contacto"
---

<Layout titulo="Contacto - Puppis clone">
    <main class="container">
        <h2 class="section-title">{tituloSeccion}</h2>
        
        <div class="contact-grid">
            <!-- Formulario -->
            <div style="background-color: var(--fondo-blanco); padding: 30px; border-radius: 20px; border: 1px solid var(--borde-claro);">
                <h3 style="color: var(--color-principal); margin-bottom: 20px;">Escribinos</h3>
                <form action="#">
                    <div class="form-group">
                        <label for="nombre">{idioma == "es" ? campos.es.nombre : campos.en.nombre}</label>
                        <input type="text" id="nombre" class="form-control" placeholder="Tu nombre" required>
                    </div>
                    <div class="form-group">
                        <label for="email">{idioma == "es" ? campos.es.correo : campos.en.correo}</label>
                        <input type="email" id="email" class="form-control" placeholder="tu@email.com" required>
                    </div>
                    <div class="form-group">
                        <label for="mensaje">{idioma == "es" ? campos.es.mensaje : campos.en.mensaje}</label>
                        <textarea id="mensaje" class="form-control" rows="5" placeholder="¿En qué podemos ayudarte a vos y a tu mascota?" required></textarea>
                    </div>
                    <button type="submit" class="btn">Enviar Mensaje</button>
                </form>
            </div>
            
            <!-- Datos de contacto -->
            <div class="contact-info-box">
                <h3 style="color: var(--color-principal); margin-bottom: 15px;">Atención al Cliente</h3>
                <p>¿Tenés alguna duda sobre tu compra online, envíos o turnos veterinarios? Estamos listos para ayudarte.</p>
                
                <div class="contact-meta">
                    <div class="contact-meta-item">
                        <span>📞</span>
                        <div>
                            <strong>Teléfono / WhatsApp Turnos:</strong><br>
                            15-2817-8667
                        </div>
                    </div>
                    <div class="contact-meta-item">
                        <span>✉️</span>
                        <div>
                            <strong>E-mail:</strong><br>
                            contacto@puppisclone.com.ar
                        </div>
                    </div>
                    <div class="contact-meta-item">
                        <span>📍</span>
                        <div>
                            <strong>Sucursales principales:</strong><br>
                            CABA, GBA Olivos, Martínez y más de 75 tiendas.
                        </div>
                    </div>
                    <div class="contact-meta-item">
                        <span>⏰</span>
                        <div>
                            <strong>Horarios:</strong><br>
                            Lunes a Sábados de 09:00 a 20:00 hs.
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
</Layout>