    <main class="container">
        <h2 class="section-title">Nuestro Catálogo</h2>
        
        <div class="filter-bar">
            <div class="filter-tags">
                <a href="#" class="filter-tag active">Todos</a>
                <a href="#" class="filter-tag">Perros</a>
                <a href="#" class="filter-tag">Gatos</a>
                <a href="#" class="filter-tag">Alimentos</a>
                <a href="#" class="filter-tag">Accesorios</a>
            </div>
            <div style="font-size: 14px; font-weight: 600; color: #666;">6 productos encontrados</div>
        </div>

        <div class="products-grid">
            <!-- Producto 1 -->
            <div class="product-card">
                <div class="product-img-placeholder">🍖<span class="badge">10% OFF</span></div>
                <div class="product-info">
                    <div class="product-brand">Royal Canin</div>
                    <div class="product-title">Alimento Mini Adulto para Perros - 7,5 Kg</div>
                    <div class="product-price">$84.600</div>
                    <a href="#" class="btn">Agregar al carrito</a>
                </div>
            </div>
            <!-- Producto 2 -->
            <div class="product-card">
                <div class="product-img-placeholder">🥫</div>
                <div class="product-info">
                    <div class="product-brand">Pro Plan</div>
                    <div class="product-title">Alimento Gato Adulto Pollo y Arroz - 3 Kg</div>
                    <div class="product-price">$38.900</div>
                    <a href="#" class="btn">Agregar al carrito</a>
                </div>
            </div>
            <!-- Producto 3 -->
            <div class="product-card">
                <div class="product-img-placeholder">💎<span class="badge">30% 2da Unid</span></div>
                <div class="product-info">
                    <div class="product-brand">Puppis</div>
                    <div class="product-title">Piedras Sanitarias Silica Gel Lavanda - 3.8 L</div>
                    <div class="product-price">$17.000</div>
                    <a href="#" class="btn">Agregar al carrito</a>
                </div>
            </div>
            <!-- Producto 4 -->
            <div class="product-card">
                <div class="product-img-placeholder">🛏️</div>
                <div class="product-info">
                    <div class="product-brand">Animal Pet</div>
                    <div class="product-title">Manta Polar Soft para Perro y Gato Gris</div>
                    <div class="product-price">$8.400</div>
                    <a href="#" class="btn">Agregar al carrito</a>
                </div>
            </div>
            <!-- Producto 5 -->
            <div class="product-card">
                <div class="product-img-placeholder">🥎</div>
                <div class="product-info">
